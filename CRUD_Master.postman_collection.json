{
  "info": {
    "_postman_id": "crud-master-collection-v1",
    "name": "CRUD Master - Microservices API",
    "description": "Complete test collection for CRUD Master microservices architecture.\n\nIncludes:\n- Movie Inventory API (CRUD operations)\n- Billing API (Order processing via RabbitMQ)\n- Health checks\n\nAutomated tests validate response schemas, status codes, and data integrity.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "26420322"
  },
  "item": [
    {
      "name": "Movies",
      "item": [
        {
          "name": "1. Create Movie",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has success flag\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Response contains movie object\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie).to.be.an('object');",
                  "    pm.expect(jsonData.movie).to.have.property('id');",
                  "    pm.expect(jsonData.movie).to.have.property('title');",
                  "    pm.expect(jsonData.movie).to.have.property('genre');",
                  "    pm.expect(jsonData.movie).to.have.property('release_year');",
                  "});",
                  "",
                  "pm.test(\"Movie has correct values\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie.title).to.equal(pm.variables.get('movieTitle'));",
                  "    pm.expect(jsonData.movie.genre).to.equal(pm.variables.get('movieGenre'));",
                  "});",
                  "",
                  "pm.test(\"Movie has auto-generated ID\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie.id).to.be.a('number');",
                  "    pm.expect(jsonData.movie.id).to.be.greaterThan(0);",
                  "    pm.variables.set('movieId', jsonData.movie.id);",
                  "});",
                  "",
                  "pm.test(\"Movie has timestamps\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie).to.have.property('created_at');",
                  "    pm.expect(jsonData.movie).to.have.property('updated_at');",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set('movieTitle', 'Inception');",
                  "pm.variables.set('movieGenre', 'Sci-Fi');",
                  "pm.variables.set('movieYear', 2010);",
                  "pm.variables.set('movieRating', 8.8);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{movieTitle}}\",\n  \"description\": \"A mind-bending thriller about dreams within dreams\",\n  \"genre\": \"{{movieGenre}}\",\n  \"release_year\": {{movieYear}},\n  \"rating\": {{movieRating}},\n  \"duration\": 148,\n  \"available_copies\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/movies",
              "host": ["{{base_url}}"],
              "path": ["api", "movies"]
            },
            "description": "Create a new movie in the inventory.\n\nRequired fields:\n- title\n- genre\n- release_year\n\nOptional fields:\n- description\n- rating\n- duration\n- available_copies"
          },
          "response": []
        },
        {
          "name": "2. Get All Movies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has success flag\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Response contains movies array\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('movies');",
                  "    pm.expect(jsonData.movies).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Response includes count\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('count');",
                  "    pm.expect(jsonData.count).to.be.a('number');",
                  "});",
                  "",
                  "pm.test(\"If movies exist, they have required properties\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.movies.length > 0) {",
                  "        var movie = jsonData.movies[0];",
                  "        pm.expect(movie).to.have.property('id');",
                  "        pm.expect(movie).to.have.property('title');",
                  "        pm.expect(movie).to.have.property('genre');",
                  "        pm.expect(movie).to.have.property('release_year');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/movies",
              "host": ["{{base_url}}"],
              "path": ["api", "movies"]
            },
            "description": "Retrieve all movies from the inventory."
          },
          "response": []
        },
        {
          "name": "3. Get Movie by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has success flag\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Response contains movie object\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('movie');",
                  "    pm.expect(jsonData.movie).to.be.an('object');",
                  "});",
                  "",
                  "pm.test(\"Movie has correct ID\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie.id).to.equal(parseInt(pm.variables.get('movieId')));",
                  "});",
                  "",
                  "pm.test(\"Movie has all required properties\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie).to.have.property('id');",
                  "    pm.expect(jsonData.movie).to.have.property('title');",
                  "    pm.expect(jsonData.movie).to.have.property('genre');",
                  "    pm.expect(jsonData.movie).to.have.property('release_year');",
                  "    pm.expect(jsonData.movie).to.have.property('created_at');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/movies/{{movieId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "movies", "{{movieId}}"]
            },
            "description": "Retrieve a specific movie by its ID."
          },
          "response": []
