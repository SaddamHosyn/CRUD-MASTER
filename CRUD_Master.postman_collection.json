                  "    pm.expect(jsonData.movie.available_copies).to.equal(3);",
                  "});",
                  "",
                  "pm.test(\"Updated_at timestamp changed\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie).to.have.property('updated_at');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 9.0,\n  \"available_copies\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/movies/{{movieId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "movies", "{{movieId}}"]
            },
            "description": "Update a movie's details (partial update supported)."
          },
          "response": []
